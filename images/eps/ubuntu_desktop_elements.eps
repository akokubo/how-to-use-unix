%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 400 300
%%Creator: GitHub Copilot
%%Title: Ubuntu Desktop Elements
%%Pages: 1
%%EndComments

% この例では単純なプレースホルダー画像を生成します
% 実際の実装では適切な画像ファイルに置き換えてください

/Times-Roman findfont 12 scalefont setfont

% 背景
0 0 moveto 400 0 lineto 400 300 lineto 0 300 lineto closepath
0.2 0.4 0.6 setrgbcolor fill

% トップバー
0 280 moveto 400 280 lineto 400 300 lineto 0 300 lineto closepath
0.2 0.2 0.2 setrgbcolor fill

% トップバーテキスト
1 1 1 setrgbcolor
20 290 moveto
(アクティビティ) show
200 290 moveto
(21:30) show
350 290 moveto
(username) show

% サイドパネル（ドック）
0 50 moveto 30 50 lineto 30 270 lineto 0 270 lineto closepath
0.2 0.2 0.2 setrgbcolor fill

% ウィンドウ
50 50 moveto 350 50 lineto 350 250 lineto 50 250 lineto closepath
1 1 1 setrgbcolor fill
0 0 0 setrgbcolor
50 50 moveto 350 50 lineto 350 250 lineto 50 250 lineto closepath stroke

% タイトルバー
50 230 moveto 350 230 lineto 350 250 lineto 50 250 lineto closepath
0.9 0.9 0.9 setrgbcolor fill
0 0 0 setrgbcolor
50 230 moveto 350 230 lineto 350 250 lineto 50 250 lineto closepath stroke

% コントロールボタン
330 240 2 0 360 arc 1 0 0 setrgbcolor fill
315 240 2 0 360 arc 1 1 0 setrgbcolor fill
300 240 2 0 360 arc 0.5 0.5 0.5 setrgbcolor fill

0 0 0 setrgbcolor
70 240 moveto
(ファイル) show

% ウィンドウコンテンツ
60 200 moveto
(ホーム) show
60 180 moveto
(ダウンロード) show
60 160 moveto
(ドキュメント) show
60 140 moveto
(デスクトップ) show

% ラベル
370 250 moveto
(トップバー) show
370 200 moveto
(ウィンドウ) show
370 150 moveto
(ドック) show
370 100 moveto
(デスクトップ) show

% 矢印
0 0 0 setrgbcolor
370 260 moveto 300 290 lineto stroke
370 210 moveto 300 200 lineto stroke
370 160 moveto 15 150 lineto stroke
370 110 moveto 200 120 lineto stroke

%%EOF
