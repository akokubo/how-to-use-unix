%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 400 300
%%Creator: GitHub Copilot
%%Title: Modern Mouse
%%Pages: 1
%%EndComments

% この例では単純なプレースホルダー画像を生成します
% 実際の実装では適切な画像ファイルに置き換えてください

/Times-Roman findfont 12 scalefont setfont

% マウス本体
150 100 moveto
180 100 lineto
200 120 lineto
200 180 lineto
180 200 lineto
120 200 lineto
100 180 lineto
100 120 lineto
120 100 lineto
150 100 lineto
0.8 0.8 0.8 setrgbcolor fill
0 0 0 setrgbcolor
150 100 moveto
180 100 lineto
200 120 lineto
200 180 lineto
180 200 lineto
120 200 lineto
100 180 lineto
100 120 lineto
120 100 lineto
150 100 lineto
closepath stroke

% マウスの左右ボタンとホイール
150 150 moveto
150 200 lineto stroke

130 190 moveto
170 190 lineto stroke

150 160 5 0 360 arc
0.7 0.7 0.7 setrgbcolor fill

% マウスジェスチャーを示す矢印
0 0 0 setrgbcolor
250 180 moveto
(左クリック) show
250 160 moveto
(右クリック) show
250 140 moveto
(ダブルクリック) show
250 120 moveto
(ドラッグ＆ドロップ) show
250 100 moveto
(ホイールスクロール) show

% 矢印
230 180 moveto 140 180 lineto stroke
230 160 moveto 160 160 lineto stroke
230 140 moveto 150 140 lineto 150 150 lineto stroke
230 120 moveto 120 120 lineto 180 160 lineto stroke
230 100 moveto 150 100 lineto 150 110 lineto stroke

%%EOF
