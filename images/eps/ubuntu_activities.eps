%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 400 300
%%Creator: GitHub Copilot
%%Title: Ubuntu Activities Screen
%%Pages: 1
%%EndComments

% この例では単純なプレースホルダー画像を生成します
% 実際の実装では適切な画像ファイルに置き換えてください

/Times-Roman findfont 12 scalefont setfont

% 背景
0 0 moveto 400 0 lineto 400 300 lineto 0 300 lineto closepath
0.2 0.2 0.2 setrgbcolor fill

% 検索ボックス
100 250 moveto 300 250 lineto 300 270 lineto 100 270 lineto closepath
0.3 0.3 0.3 setrgbcolor fill
0 0 0 setrgbcolor
100 250 moveto 300 250 lineto 300 270 lineto 100 270 lineto closepath stroke

1 1 1 setrgbcolor
150 260 moveto
(アプリケーションを検索...) show

% タブ
0.5 0.5 0.5 setrgbcolor
100 230 moveto
(アプリケーション) show
200 230 moveto
(ドキュメント) show

% アイコングリッド
1 1 1 setrgbcolor
70 200 moveto
(Firefox) show
150 200 moveto
(Terminal) show
230 200 moveto
(Files) show
310 200 moveto
(Settings) show

70 160 moveto
(LibreOffice) show
150 160 moveto
(Calculator) show
230 160 moveto
(Calendar) show
310 160 moveto
(Thunderbird) show

70 120 moveto
(GIMP) show
150 120 moveto
(Gedit) show
230 120 moveto
(Help) show
310 120 moveto
(Ubuntu Software) show

% ドック
50 40 moveto 350 40 lineto 350 60 lineto 50 60 lineto closepath
0.3 0.3 0.3 setrgbcolor fill

1 1 1 setrgbcolor
70 50 moveto
(Firefox) show
130 50 moveto
(Files) show
180 50 moveto
(Terminal) show
250 50 moveto
(Settings) show
310 50 moveto
(Ubuntu Software) show

