/initializeVars{
	/AGMGrad_d255 256 array def
	0 1 255{
		AGMGrad_d255 exch dup 255 div put
	}bind for
	/AGMGrad_sSave nd
	/AGMGrad_dUserSpace matrix defaultmatrix def
	/AGMGrad_bUMatrix matrix def
