%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 400 300
%%Creator: GitHub Copilot
%%Title: macOS Desktop Elements
%%Pages: 1
%%EndComments

% この例では単純なプレースホルダー画像を生成します
% 実際の実装では適切な画像ファイルに置き換えてください

/Times-Roman findfont 12 scalefont setfont

% 背景
0 0 moveto 400 0 lineto 400 300 lineto 0 300 lineto closepath
0.7 0.8 1.0 setrgbcolor fill

% メニューバー
0 280 moveto 400 280 lineto 400 300 lineto 0 300 lineto closepath
0.2 0.2 0.2 setrgbcolor fill

% メニューバーテキスト
1 1 1 setrgbcolor
20 290 moveto
(Apple) show
60 290 moveto
(File) show
90 290 moveto
(Edit) show
120 290 moveto
(View) show
300 290 moveto
(21:30) show
350 290 moveto
(username) show

% ウィンドウ
50 50 moveto 350 50 lineto 350 250 lineto 50 250 lineto closepath
1 1 1 setrgbcolor fill
0 0 0 setrgbcolor
50 50 moveto 350 50 lineto 350 250 lineto 50 250 lineto closepath stroke

% タイトルバー
50 230 moveto 350 230 lineto 350 250 lineto 50 250 lineto closepath
0.9 0.9 0.9 setrgbcolor fill
0 0 0 setrgbcolor
50 230 moveto 350 230 lineto 350 250 lineto 50 250 lineto closepath stroke

% コントロールボタン
60 240 2 0 360 arc 1 0 0 setrgbcolor fill
75 240 2 0 360 arc 1 0.8 0 setrgbcolor fill
90 240 2 0 360 arc 0 0.8 0 setrgbcolor fill

0 0 0 setrgbcolor
180 240 moveto
(Finder) show

% ウィンドウコンテンツ
60 200 moveto
(デスクトップ) show
60 180 moveto
(ダウンロード) show
60 160 moveto
(書類) show
60 140 moveto
(アプリケーション) show

% Dock
100 10 moveto 300 10 lineto 300 30 lineto 100 30 lineto closepath
0.5 0.5 0.5 setrgbcolor fill
0 0 0 setrgbcolor

% Dockラベル
20 150 moveto
(デスクトップ) show
20 130 moveto
(Dock) show
20 110 moveto
(メニューバー) show
20 90 moveto
(ウィンドウ) show

% 矢印
0 0 0 setrgbcolor
15 150 moveto 50 200 lineto stroke
15 130 moveto 150 25 lineto stroke
15 110 moveto 100 290 lineto stroke
15 90 moveto 200 180 lineto stroke

%%EOF
