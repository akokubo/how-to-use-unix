%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 400 300
%%Creator: GitHub Copilot
%%Title: Window Elements
%%Pages: 1
%%EndComments

% この例では単純なプレースホルダー画像を生成します
% 実際の実装では適切な画像ファイルに置き換えてください

/Times-Roman findfont 12 scalefont setfont

% ウィンドウ
50 50 moveto 350 50 lineto 350 250 lineto 50 250 lineto closepath
1 1 1 setrgbcolor fill
0 0 0 setrgbcolor
50 50 moveto 350 50 lineto 350 250 lineto 50 250 lineto closepath stroke

% タイトルバー
50 230 moveto 350 230 lineto 350 250 lineto 50 250 lineto closepath
0.9 0.9 0.9 setrgbcolor fill
0 0 0 setrgbcolor
50 230 moveto 350 230 lineto 350 250 lineto 50 250 lineto closepath stroke

% macOS風コントロールボタン（左）
60 240 5 0 360 arc 1 0 0 setrgbcolor fill
75 240 5 0 360 arc 1 0.8 0 setrgbcolor fill
90 240 5 0 360 arc 0 0.8 0 setrgbcolor fill

0 0 0 setrgbcolor
150 240 moveto
(ウィンドウのタイトル) show

% Windows/Ubuntu風コントロールボタン（右）
320 240 5 0 360 arc 1 0 0 setrgbcolor fill
300 240 5 0 360 arc 0.5 0.5 0.5 setrgbcolor fill
280 240 5 0 360 arc 0 0.8 0 setrgbcolor fill

% スクロールバー
350 60 moveto 350 230 lineto stroke
345 100 5 0 360 arc 0.8 0.8 0.8 setrgbcolor fill

% ステータスバー
50 50 moveto 350 50 lineto 350 65 lineto 50 65 lineto closepath
0.9 0.9 0.9 setrgbcolor fill
0 0 0 setrgbcolor
50 50 moveto 350 50 lineto 350 65 lineto 50 65 lineto closepath stroke

% ウィンドウコンテンツ
60 200 moveto
(ウィンドウの内容) show

% ラベル
20 240 moveto
(タイトルバー) show
360 180 moveto
(スクロールバー) show
60 40 moveto
(ステータスバー) show
100 260 moveto
(コントロールボタン) show
340 260 moveto
(コントロールボタン) show
300 100 moveto
(コンテンツ領域) show
360 75 moveto
(リサイズ) show

% 矢印
0 0 0 setrgbcolor
360 190 moveto 350 150 lineto stroke
50 40 moveto 100 55 lineto stroke
100 270 moveto 75 240 lineto stroke
340 270 moveto 320 240 lineto stroke
300 110 moveto 200 150 lineto stroke

% リサイズマーク
345 55 moveto 350 55 lineto 350 60 lineto stroke
340 55 moveto 350 55 lineto 350 65 lineto stroke
335 55 moveto 350 55 lineto 350 70 lineto stroke

%%EOF
